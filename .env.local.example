# URL the Next.js server uses to call the Go API (server-side, SSR).
# In Docker Compose this is typically the API service name.
API_BASE_URL=http://localhost:8080

# Optional: cookie name issued by the Go API for sessions.
SESSION_COOKIE_NAME=session

# ── Third-party API keys ──────────────────────────────────────────────────────

# Spotify API credentials for artist quick-import on the submit page.
# Get them at https://developer.spotify.com/dashboard → Create app.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Dev / mock flags ──────────────────────────────────────────────────────────

# Set to "true" to render the authenticated UI without a running Go API.
# When the API is unreachable, loadSession() will return the fixture user
# (insaf@example.com / @insaf, role=user) so you can see groups, the rating
# widget, and all auth-gated UI elements during local development.
# NEVER set this in production — it is ignored when NODE_ENV=production.
MOCK_AUTH=true
